{
  "name": "@vikil143/react-starter-cli",
  "version": "3.0.0",
  "description": "CLI to scaffold Vite React apps with JavaScript or TypeScript, React Router, Redux Toolkit, Axios, Tailwind CSS, ESLint, Prettier, and reusable UI components.",
  "main": "src/commands/create.js",
  "bin": {
    "react-starter-cli": "bin/index.js"
  },
  "scripts": {
    "start": "node ./bin/index.js",
    "test": "node --input-type=module -e \"import('./src/commands/create.js').then(() => console.log('CLI module loaded'))\""
  },
  "keywords": [
    "cli",
    "react",
    "vite",
    "react-cli",
    "react-starter",
    "vite-react",
    "vite-react-starter",
    "react-boilerplate",
    "scaffold",
    "scaffolding",
    "starter",
    "typescript",
    "javascript",
    "react-router",
    "redux-toolkit",
    "tailwindcss"
  ],
  "author": "Vikil Lakkavatri",
  "license": "ISC",
  "homepage": "https://github.com/vikil143/react-starter-cli#readme",
  "bugs": {
    "url": "https://github.com/vikil143/react-starter-cli/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vikil143/react-starter-cli.git"
  },
  "type": "module",
  "dependencies": {
    "@inquirer/prompts": "^8.3.2",
    "chalk": "^5.6.2",
    "commander": "^14.0.3"
  }
}
